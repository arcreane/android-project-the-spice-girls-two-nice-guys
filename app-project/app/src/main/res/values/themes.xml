<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.TheSpice" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Main brand colors -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorAccent">@color/colorSecondaryGlow</item>

        <!-- App background -->
        <item name="android:windowBackground">@color/colorBackground</item>

        <!-- System bars -->
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:navigationBarColor">@color/colorBackground</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Text -->
        <item name="android:textColorPrimary">@color/colorTextPrimary</item>
        <item name="android:textColorSecondary">@color/colorTextSecondary</item>

        <!-- Default font -->
        <item name="android:fontFamily">sans</item>

        <!-- Material surfaces -->
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorSurfaceVariant">@color/colorSurfaceSoft</item>
        <item name="colorOnSurface">@color/colorTextPrimary</item>
        <item name="colorOnSurfaceVariant">@color/colorTextSecondary</item>
        <item name="colorOnPrimary">@color/colorBackground</item>
        <item name="colorOnSecondary">@color/colorTextPrimary</item>
        <item name="colorOnError">@color/colorBackground</item>
        <item name="colorOutline">@color/colorDivider</item>

    </style>

</resources>