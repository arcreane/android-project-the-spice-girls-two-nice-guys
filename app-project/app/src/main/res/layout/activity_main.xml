<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/ScreenRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    >

    <!-- soft neon glow block -->
    <View
        android:id="@+id/glowOrb"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:background="@drawable/bg_neon_glow"
        android:alpha="0.85"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-40dp"
        android:layout_marginEnd="-40dp" />

    <TextView
        android:id="@+id/appNameText"
        style="@style/TextTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Baromètre"
        android:textSize="34sp"
        android:letterSpacing="0.04"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="72dp" />

    <TextView
        android:id="@+id/taglineText"
        style="@style/TextSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Find the right bar for your night."
        android:textSize="17sp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/appNameText"
        app:layout_constraintStart_toStartOf="@id/appNameText"
        app:layout_constraintEnd_toEndOf="@id/appNameText" />

    <LinearLayout
        android:id="@+id/neonCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp"
        android:background="@drawable/bg_neon_card"
        android:layout_marginTop="42dp"
        app:layout_constraintTop_toBottomOf="@id/taglineText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            style="@style/NeonPrimaryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NEON NIGHTLIFE MODE"
            android:letterSpacing="0.08"
            android:textSize="12sp" />

        <TextView
            style="@style/TextBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Search by vibe, rating, distance and type. Save favorites and discover places near you."
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>

    <Button
        android:id="@+id/testThemeButton"
        style="@style/PrimaryButton"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:text="Find bars near me"
        android:textAllCaps="false"
        android:layout_marginTop="36dp"
        app:layout_constraintTop_toBottomOf="@id/neonCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/testSettingsButton"
        style="@style/SecondaryButton"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:text="Open settings"
        android:textAllCaps="false"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/testThemeButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>